# ── Base de datos (PostgreSQL) ────────────────────────────────────────────────
# Formato: postgresql://usuario:password@host:puerto/nombre_db?schema=public
# Para desarrollo local con Docker:
DATABASE_URL="postgresql://flowforge:flowforge123@localhost:5432/flowforge?schema=public"

# Para producción en Vercel (Neon/Supabase):
# DATABASE_URL="postgresql://user:password@db.neon.tech/flowforge?sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="cambia-esto-por-una-clave-secreta-larga-y-aleatoria"

# ── Google OAuth (opcional) ──────────────────────────────────────────────────
# Crear en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="tu-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="tu-google-client-secret"

# ── JWT (tokens de refresh) ──────────────────────────────────────────────────
JWT_SECRET="cambia-esto-por-otra-clave-secreta-diferente"
JWT_EXPIRES_IN="7d"

# ── Vercel Blob (almacenamiento de archivos en la nube) ─────────────────────
# Crear en: https://vercel.com/dashboard/stores/blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_tu_token_aqui"

MAX_FILE_SIZE_MB="10"
